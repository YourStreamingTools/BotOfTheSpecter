# BotOfTheSpecter — Caddy config for the web server.
#
# Covers all 13 surfaces (10 PHP frontends + 3 static asset hosts).
# Caddy auto-issues + auto-renews Let's Encrypt certs.
#
# Wildcards (*.specterbot.app, *.yourlinks.click) use Cloudflare DNS-01;
# everything else uses HTTP-01 automatically.
#
# Reload with:   systemctl reload caddy
# Watch logs:    journalctl -fu caddy

{
    email admin@botofthespecter.com

    # All four zones (botofthespecter.com, botspecter.com, yourlinks.click,
    # specterbot.app) are on Cloudflare, so use DNS-01 globally. Works for
    # wildcards AND apex domains, and survives Cloudflare proxy being on.
    acme_dns cloudflare {env.CF_API_TOKEN}
}

# ===== Reusable snippets =====

(security) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        -X-Powered-By
    }
}

(php_app) {
    @blocked {
        path *.conf *.env *.sql *.md *.ini *.log /database.php
    }
    handle @blocked {
        respond 403
    }
    php_fastcgi unix//run/php/php8.5-fpm.sock
    encode zstd gzip
    file_server
    import security
}

(static_long_cache) {
    file_server
    encode zstd gzip
    import security
    @assets path *.jpg *.jpeg *.png *.gif *.webp *.svg *.ico *.css *.js *.mp3 *.wav *.mp4 *.m4a *.woff *.woff2 *.ttf
    header @assets Cache-Control "public, max-age=31536000, immutable"
}

# Static asset hosts proxy to the object-storage origin (STORAGE_HOST /
# STORAGE_PREFIX from caddy.env); each host appends its bucket prefix.
(asset_origin) {
    reverse_proxy {env.STORAGE_HOST}:443 {
        header_up Host {env.STORAGE_HOST}
        transport http {
            tls
        }
    }
    import security
    @assets path *.jpg *.jpeg *.png *.gif *.webp *.svg *.ico *.css *.js *.mp3 *.wav *.mp4 *.m4a *.ogg *.woff *.woff2 *.ttf
    header @assets Cache-Control "public, max-age=31536000, immutable"
}

