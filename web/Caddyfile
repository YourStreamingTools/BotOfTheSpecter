# Apex + www serve the landing page directly from the /home/ subdirectory.
# Using /home/ as the docroot (not /var/www/specterbotapp) means relative
# asset paths in the landing page HTML resolve naturally.
specterbot.app, www.specterbot.app {
    root * /var/www/specterbotapp/home
    import php_app
    log {
        output file /var/log/caddy/specterbotapp.log
    }
}

# Per-user subdomains: docroot embeds the leftmost host label, so
# gfaundead.specterbot.app -> /var/www/specterbotapp/gfaundead/.
# No rewrite needed -- avoids the trailing-slash + index.php path bug
# that hits when both the URI ends with / and php_fastcgi appends /index.php.
# If the user dir doesn't exist (or any path under it 404s), handle_errors
# bounces the visitor to the apex.
*.specterbot.app {
    root * /var/www/specterbotapp/{labels.2}

    handle_errors {
        @404 expression {http.error.status_code} == 404
        redir @404 https://specterbot.app/
    }

    import php_app
    log {
        output file /var/log/caddy/specterbotapp-users.log
    }
}

specterbot.systems, www.specterbot.systems {
    root * /var/www/specterbotsystems

    # Redirect /mybot/* to mybot.specterbot.systems subdomain
    @mybot path /mybot /mybot/*
    handle @mybot {
        uri strip_prefix /mybot
        redir https://mybot.specterbot.systems{uri} 301
    }

    import php_app
    log {
        output file /var/log/caddy/specterbot-systems.log
    }
}

mybot.specterbot.systems {
    root * /var/www/specterbotsystems/mybot
    import php_app
    log {
        output file /var/log/caddy/mybot-specterbot-systems.log
    }
}

yourchat.botofthespecter.com {
    root * /var/www/yourchat
    import php_app
    log {
        output file /var/log/caddy/yourchat.log
    }
}

# YourLinks.click — the apex is the app/dashboard, served normally. The wildcard
# subdomains (username.yourlinks.click) are public profiles + short links, all
# dispatched through redirect.php, which reads the username from the Host header.
# This replaces the app's Apache .htaccess mod_rewrite rules — Caddy never reads
# .htaccess, which is why every subdomain was falling through to index.php.
yourlinks.click {
    root * /var/www/yourlinks.click
    import php_app
    log {
        output file /var/log/caddy/yourlinks.log
    }
}

# www → apex. Without this, redirect.php sends www to "/" on the same host and
# loops, because the wildcard block below routes "/" back into redirect.php.
www.yourlinks.click {
    redir https://yourlinks.click{uri} permanent
}

*.yourlinks.click {
    root * /var/www/yourlinks.click

    # "/" on a subdomain is the linktree / Twitch-redirect landing page.
    @root path /
    rewrite @root /redirect.php

    # "/<linkname>" that is not a real static file is a short link. redirect.php
    # still sees the original REQUEST_URI (Caddy preserves it across rewrites),
    # so it extracts the link name and Host-based username just like mod_rewrite.
    @shortlink {
        not path /redirect.php*
        not file
    }
    rewrite @shortlink /redirect.php

    import php_app
    log {
        output file /var/log/caddy/yourlinks.log
    }
}

streamersconnect.com, www.streamersconnect.com {
    root * /var/www/StreamersConnect
    import php_app
    log {
        output file /var/log/caddy/streamersconnect.log
    }
}

# ===== Static asset hosts =====

cdn.botofthespecter.com {
    rewrite * {env.STORAGE_PREFIX}/cdn{uri}
    # own proxy block: strip the origin's reflected CORS header so it doesn't
    # collide with the Access-Control-Allow-Origin we set for the fonts below.
    reverse_proxy {env.STORAGE_HOST}:443 {
        header_up Host {env.STORAGE_HOST}
        transport http {
            tls
        }
        header_down -Access-Control-Allow-Origin
        header_down -Access-Control-Allow-Methods
    }
    import security
    encode zstd gzip
    @assets path *.jpg *.jpeg *.png *.gif *.webp *.svg *.ico *.css *.js *.mp3 *.wav *.mp4 *.m4a *.ogg *.woff *.woff2 *.ttf
    header @assets Cache-Control "public, max-age=31536000, immutable"
    header /css/fontawesome* Access-Control-Allow-Origin "*"
    header /css/fontawesome* Access-Control-Allow-Methods "GET, OPTIONS"
    log {
        output file /var/log/caddy/cdn.log
    }
}

walkons.botofthespecter.com {
    rewrite * {env.STORAGE_PREFIX}/walkons{uri}
    import asset_origin
    log {
        output file /var/log/caddy/walkons.log
    }
}

