# Apex + www serve the landing page from /home/.
specterbot.app, www.specterbot.app {
    root * /var/www/specterbotapp
    @root path /
    rewrite @root /home/index.php
    import php_app
    log {
        output file /var/log/caddy/specterbotapp.log
    }
}

# Per-user subdomains: gfaundead.specterbot.app -> /var/www/specterbotapp/gfaundead/...
# {labels.2} is the leftmost label of the Host header.
# If the user's directory exists, prepend it to the URI and serve their pages.
# Otherwise the subdomain is unknown -- redirect to the apex.
*.specterbot.app {
    root * /var/www/specterbotapp

    @user_exists file {
        try_files /{labels.2}
    }
    handle @user_exists {
        rewrite * /{labels.2}{uri}
        import php_app
    }
    handle {
        redir https://specterbot.app/
    }

    log {
        output file /var/log/caddy/specterbotapp-users.log
    }
}

specterbotsystems.botofthespecter.com {
