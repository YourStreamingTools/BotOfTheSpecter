# Apex + www serve the landing page directly from the /home/ subdirectory.
# Using /home/ as the docroot (not /var/www/specterbotapp) means relative
# asset paths in the landing page HTML resolve naturally.
specterbot.app, www.specterbot.app {
    root * /var/www/specterbotapp/home
    import php_app
    log {
        output file /var/log/caddy/specterbotapp.log
    }
}

# Per-user subdomains: docroot embeds the leftmost host label, so
# gfaundead.specterbot.app -> /var/www/specterbotapp/gfaundead/.
# No rewrite needed -- avoids the trailing-slash + index.php path bug
# that hits when both the URI ends with / and php_fastcgi appends /index.php.
# If the user dir doesn't exist (or any path under it 404s), handle_errors
# bounces the visitor to the apex.
*.specterbot.app {
    root * /var/www/specterbotapp/{labels.2}

    handle_errors {
        @404 expression {http.error.status_code} == 404
        redir @404 https://specterbot.app/
    }

    import php_app
    log {
        output file /var/log/caddy/specterbotapp-users.log
    }
}

specterbot.systems, www.specterbot.systems {
    root * /var/www/specterbotsystems

    # Redirect /mybot/* to mybot.specterbot.systems subdomain
    @mybot path /mybot /mybot/*
    handle @mybot {
        uri strip_prefix /mybot
        redir https://mybot.specterbot.systems{uri} 301
    }

    import php_app
    log {
        output file /var/log/caddy/specterbot-systems.log
    }
}

mybot.specterbot.systems {
    root * /var/www/specterbotsystems/mybot
    import php_app
    log {
        output file /var/log/caddy/mybot-specterbot-systems.log
    }
}

yourchat.botofthespecter.com {
    root * /var/www/yourchat
    import php_app
    log {
        output file /var/log/caddy/yourchat.log
    }
}

yourlinks.click, *.yourlinks.click {
    root * /var/www/yourlinks.click
    import php_app
    log {
        output file /var/log/caddy/yourlinks.log
    }
}

